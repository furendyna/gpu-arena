# Base URL of the GPU Arena API (apps/api). Used by the browser.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Public links shown in the header/footer.
NEXT_PUBLIC_GITHUB_URL=https://github.com/furendyna/gpu-arena
NEXT_PUBLIC_TWITTER_URL=https://x.com/gpuarena

# Solana network the wallet connects to. Use "devnet" to test for free first.
NEXT_PUBLIC_SOLANA_CLUSTER=mainnet-beta
# Optional custom RPC (Helius/Triton/QuickNode). Falls back to public RPC.
NEXT_PUBLIC_SOLANA_RPC_URL=

# Filled in by `npm run create-token --workspace @gpu-arena/api`.
# (The web app also reads these live from the API's /api/config.)
NEXT_PUBLIC_PRIZE_TOKEN_MINT=
NEXT_PUBLIC_TREASURY_ADDRESS=
