# ---- GPU Arena agent config ----

# Most people don't need this file — just run:
#   npm run agent -- --wallet <YOUR_SOLANA_ADDRESS>
# These env vars are optional fallbacks for the CLI flags (--api, --handle, --wallet).

API_URL=http://localhost:4000
HANDLE=my-rig

# Address your prizes are paid to (public address only — no private key).
# Same as: npm run agent -- --wallet <YOUR_SOLANA_ADDRESS>
PAYOUT_WALLET=

# Path to this agent's signing keypair (auto-created if missing). Used only to
# prove the GPU is real (anti-cheat) — NOT where prizes go.
WALLET_PATH=./agent.keypair.json

# Override detected GPU (testing only). Leave empty to use real nvidia-smi detection.
GPU_OVERRIDE=

# Optional local inference endpoint (Ollama-compatible). If unset, a stub answer is used.
# Example: http://localhost:11434/api/generate
OLLAMA_URL=

# Different model per tier — weaker GPUs (Tier 1) run a smaller model,
# stronger GPUs (Tier 2) run a bigger one. The agent auto-picks based on the
# tier your detected GPU lands in.
OLLAMA_MODEL_TIER1=llama3.2:3b
OLLAMA_MODEL_TIER2=llama3.1:8b

# ---- Image bounties (optional) ----
# To compete in image-generation bounties, run Automatic1111 SD WebUI with the
# API enabled (launch with --api) and point this at it. Without it, the agent
# simply skips image bounties.
#   Example: http://127.0.0.1:7860
IMAGE_API_URL=
# Optional per-tier checkpoint override (Automatic1111 sd_model_checkpoint name).
# Leave empty to use whatever model is currently loaded in the WebUI.
# Tier 1 (weaker GPUs) should use a lighter/faster model; Tier 2 a higher-quality one.
IMAGE_MODEL_TIER1=
IMAGE_MODEL_TIER2=
