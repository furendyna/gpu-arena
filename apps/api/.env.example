# ---- GPU Arena API config ----

PORT=4000

# Solana — MAINNET. Use a reliable RPC (Helius/Triton/QuickNode recommended).
SOLANA_CLUSTER=mainnet-beta
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# SPL mint of the prize token (the "arena token").
PRIZE_TOKEN_MINT=

# Treasury wallet that custodially holds bounty escrow and pays winners.
# base58-encoded secret key. NEVER commit the real value. Keep this offline/secret.
TREASURY_SECRET_KEY=

# Safety switch: payouts are simulated unless this is "true".
ENABLE_REAL_PAYOUTS=false

# AI judge (blind scoring). If unset, a deterministic local heuristic is used.
OPENAI_API_KEY=
JUDGE_MODEL=gpt-4o-mini
