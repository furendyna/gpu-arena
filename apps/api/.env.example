# ---- GPU Arena API config ----

PORT=4000

# Database — Upstash Redis (required). Create a DB at https://console.upstash.com
# and copy the REST URL + token here.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Solana — MAINNET. Use a reliable RPC (Helius/Triton/QuickNode recommended).
SOLANA_CLUSTER=mainnet-beta
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# SPL mint of the prize token (the "arena token").
# Created by: npm run create-token --workspace @gpu-arena/api
PRIZE_TOKEN_MINT=

# Treasury wallet that custodially holds bounty escrow and pays winners.
# base58-encoded secret key. NEVER commit the real value. Keep this offline/secret.
# (When set, the API derives the treasury address from it; otherwise set TREASURY_ADDRESS.)
TREASURY_SECRET_KEY=
# Public treasury address (only needed if TREASURY_SECRET_KEY is not set here).
TREASURY_ADDRESS=

# Token supply settings used by the create-token script.
TOKEN_DECIMALS=9
INITIAL_SUPPLY=1000000000

# When PRIZE_TOKEN_MINT + treasury are set, new bounties MUST be escrowed on-chain:
# the creator's wallet transfers the prize into the treasury and the API verifies it.

# Safety switch: payouts are simulated unless this is "true".
ENABLE_REAL_PAYOUTS=false

# AI judge (blind scoring) runs on a LOCAL Ollama model.
# Pull one first:  ollama pull llama3.1:8b
# If Ollama is unreachable, a deterministic offline heuristic is used automatically.
OLLAMA_URL=http://localhost:11434
JUDGE_MODEL=llama3.1:8b

# Vision model used to judge IMAGE bounties (scores how well each image matches
# the prompt). Pull it first:  ollama pull llama3.2-vision
# If unavailable, image battles fall back to a simple "submitted + fast" score.
VISION_JUDGE_MODEL=llama3.2-vision

# Arena orchestrator timing (ms). Bounties battle one-at-a-time (FIFO).
# Submission window must exceed the agent poll interval (~2.5s).
BATTLE_WINDOW_MS=9000
# Image bounties take much longer to generate, so they get their own window.
IMAGE_BATTLE_WINDOW_MS=120000
JUDGE_PAUSE_MS=1500
REVEAL_MS=6000
