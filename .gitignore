!packages/shared/dist/
!packages/shared/dist/**
.next/
out/
build/
coverage/
*.tsbuildinfo

# env / secrets — NEVER commit treasury or wallet keys
.env
.env.*
!.env.example
*.keypair.json
treasury*.json
wallet*.json

# logs
*.log
npm-debug.log*

# os
.DS_Store
Thumbs.db
